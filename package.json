{
  "name": "ats-engine",
  "version": "1.0.0",
  "description": "ATS engine with deterministic scoring + LLM layer.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "ats": "tsx src/cli/run.ts",
    "ats:evaluate": "tsx src/cli/evaluate.ts",
    "ats:local": "ATS_MODE=local tsx src/cli/run.ts",
    "ats:portfolio": "ATS_MODE=portfolio tsx src/cli/run.ts",
    "ats:serve": "tsx src/server/atsServer.ts",
    "ui:build": "npm run build --prefix ui",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "diff": "^8.0.4",
    "dotenv": "^17.4.0",
    "portfolio-backend": "file:../portfolio/backend",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
